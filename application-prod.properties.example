# Example production overrides if you deploy with a file-based configuration.
# In production, prefer setting the secret values through environment variables.

spring.datasource.username=${MYSQL_USER}
spring.datasource.password=${MYSQL_PASSWORD}
kma.authKey=${KMA_AUTH_KEY}

# Session cookie should be secure behind HTTPS.
server.servlet.session.cookie.secure=true
server.servlet.session.timeout=30m
