# Copy this file to application-local.properties in the project root.
# This file is gitignored and is intended for local development only.
#
# PowerShell:
# Copy-Item .\application-local.properties.example .\application-local.properties

# Local MySQL
spring.datasource.username=root
spring.datasource.password=YOUR_MYSQL_PASSWORD

# External API key
kma.authKey=YOUR_KMA_AUTH_KEY

# Local browser/http settings
SESSION_COOKIE_SECURE=false
SESSION_TIMEOUT=30m
